<form>
    <div class="party-loot__currency-row flexrow flex1">
        <div class="party-loot__currency-entry flexrow">
            <input value="{{currency.pp}}" type="number" name="currency.pp" data-dtype="Number" />
            <span class="flex0">{{localize "PARTY-LOOT.pp"}}</span>
        </div>
        <div class="party-loot__currency-entry flexrow">
            <input value="{{currency.gp}}" type="number" name="currency.gp" data-dtype="Number" />
            <span class="flex0">{{localize "PARTY-LOOT.gp"}}</span>
        </div>
        <div class="party-loot__currency-entry flexrow">
            <input value="{{currency.ep}}" type="number" name="currency.ep" data-dtype="Number" />
            <span class="flex0">{{localize "PARTY-LOOT.ep"}}</span>
        </div>
        <div class="party-loot__currency-entry flexrow">
            <input value="{{currency.sp}}" type="number" name="currency.sp" data-dtype="Number" />
            <span class="flex0">{{localize "PARTY-LOOT.sp"}}</span>
        </div>
        <div class="party-loot__currency-entry flexrow">
            <input value="{{currency.cp}}" type="number" name="currency.cp" data-dtype="Number" />
            <span class="flex0">{{localize "PARTY-LOOT.cp"}}</span>
        </div>
    </div>

    <button class="flex0" type="submit" name="submit"><i class="fas fa-hand fa-rotate-90"></i> {{localize "PARTY-LOOT.take-currency"}}</button>
</form>
